# SignX-Takeoff Environment Configuration
# Copy to ../.env (parent SignX directory) and fill in real values.
# The app loads .env from one directory above the project root.

# ── Notion API ──────────────────────────────────────────────────────
NOTION_TOKEN=ntn_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NOTION_VAULT_ROOT=294c1e58d2dd80d3be09f6b2d16eda2c
NOTION_BID_PIPELINE=304c1e58d2dd814aae63c6a0d44e6679

# ── Anthropic (Claude Haiku email classification) ───────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── SMTP for SMS Notifications ──────────────────────────────────────
# Required: both SMTP_SERVER and SMTP_FROM must be set for SMS to work.
# For M365 authenticated SMTP (recommended for Eagle Sign):
#   Server: smtp.office365.com
#   Port:   587 (STARTTLS)
#   User:   your M365 email (e.g., notifications@eaglesign.net)
#   Pass:   App password (NOT your login password — create at https://mysignins.microsoft.com/security-info)
#   From:   must match SMTP_USER exactly (M365 enforces sender = auth identity)
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SMTP_FROM=notifications@eaglesign.net
SMTP_USER=notifications@eaglesign.net
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# ── SMS Destination ─────────────────────────────────────────────────
# 10-digit US phone number (no dashes, no +1 prefix)
SMS_PHONE=7122666482
# Carrier email-to-SMS gateways:
#   Verizon:    vtext.com
#   AT&T:       txt.att.net
#   T-Mobile:   tmomail.net
#   US Cellular: email.uscc.net
SMS_CARRIER_GATEWAY=vtext.com

# ── Power Automate Webhook (optional backup notification) ───────────
# If set, a JSON payload is POSTed here in addition to SMS.
# Create a "When an HTTP request is received" trigger in Power Automate.
NOTIFY_WEBHOOK_URL=
