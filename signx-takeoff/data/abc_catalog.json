    "Constant to Post & panel": {
      "labor_id": "LABOR95a",
      "params": [
        "HT",
        "(NM15hL9+NM15iL9+NM15jL7)>0)*((NM15hL9+N",
        "15iL9+NM15jL7)<=12)*1+((NM15hL9+NM15iL9+NM15jL7)>12)*((NM15hL9+NM15iL9+NM15jL",
        ")<=18)*1.5+((NM15hL9+NM15iL9+NM15jL7)>18)*((NM15hL9+NM1",
        "iL9+NM15jL7)<=24)*2+((NM15hL9+NM15iL9+NM15jL7)>24)*((",
        "LNTH",
        "(NM15hL10+NM15iL10+NM15jL8)>0)*((NM15hL1",
        "+NM15iL10+NM15jL8)<=12)*1+((NM15hL10+NM15iL10+NM",
        "5jL8)>12)*((NM15hL10+NM15iL10+NM15jL8)<=18)*1.5+(",
        "NM15hL10+NM15iL10+NM15jL8)>18)*((NM15hL1",
        "+NM15iL10+NM15jL8)<=24)*2+((NM15hL10+NM15iL10+NM",
        "5jL8)>24)*((NM15hL10+NM15iL10+NM15jL8)<=30)*2.5+(",
        "NM15hL10+NM15iL10+NM15jL8)>30)*((NM15hL1",
        "+NM15iL10+NM15jL8)<=36)*3+((NM15hL10+NM15iL10+NM",
        "5jL8)>36)*((NM15hL10+NM15iL10+NM15jL8)<=48)*4+((N",
        "15hL10+NM15iL10+NM15jL8)>48)*((NM15hL10+NM15iL10+NM15jL8)<=60)*5+((NM15hL10+N",
        "15iL10+NM15jL8)>60)*((NM15hL10+NM15iL10+NM15jL8)<=72)*6+((NM15hL10+NM15iL10+N",
        "P",
        "HT*2+LNTH*2",
        "post_panel_perim",
        "P+(P>0)*(P<12)*0.75+(P>=12)*1",
        "post_panel_area",
        "HT*LNTH"
      ],
      "formula": "(((post_panel_perim)<14)*((NM15gL3+NM15gL6+NM15gL4+NM15gL7)*0.925+NM15gL5*0.750)+((post_panel_perim)>=14)*((NM15gL3+NM15gL6+NM15gL4+NM15gL7)*0.990+NM15gL5*0.875))*(1+(NM15gL4+NM15gL7)*0.15)*(1-NM14L19*0.5)"
